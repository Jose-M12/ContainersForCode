{
  "apiVersion": "containersagents.dev/v2alpha1",
  "kind": "Profile",
  "metadata": { "name": "pwsh-dotnet" },
  "spec": {
    "image": {
      "mode": "build",
      "repository": "localhost/containersagents-v2/pwsh-dotnet",
      "containerfile": "Containerfile",
      "context": ".",
      "pullPolicy": "newer"
    },
    "runtime": {
      "user": "agent", "uid": 1000, "gid": 1000,
      "home": "/home/agent", "workdir": "/workspace",
      "shell": ["pwsh", "-NoLogo"],
      "keepalive": ["sleep", "infinity"],
      "identityMode": "managed-user", "allowSudo": true,
      "caBundle": "/etc/ssl/certs/ca-certificates.crt"
    },
    "features": ["common-cli", "powershell", "dotnet"],
    "defaults": { "securityClass": "development", "resourceClass": "balanced", "rootfsPersistence": "persistent" },
    "minimumResources": { "memoryMiB": 2048, "cpus": 1, "pids": 1024, "shmMiB": 256 },
    "checks": [
      { "name": "powershell", "command": ["pwsh", "-NoLogo", "-Command", "$PSVersionTable.PSVersion.ToString()"] },
      { "name": "dotnet", "command": ["dotnet", "--info"] },
      { "name": "git", "command": ["git", "--version"] }
    ]
  }
}
